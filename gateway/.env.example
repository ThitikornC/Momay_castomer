# ── MongoDB ── (ใช้ cluster เดียวกับทุก service)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/momay

# ── Gateway server ──
GATEWAY_PORT=8002
GATEWAY_KEY=your-secret-key-for-esp32-auth

# ── MQTT (Tasmota) ── broker ส่วนตัว (ใส่ port ใน URL) — อย่าใช้ public broker
MQTT_BROKER=mqtt://your-broker-host:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=momay-gateway

# ── Auto control (booking → เปิด/ปิดสวิตช์) ยุบมาจาก Control ──
AUTO_CONTROL_ENABLED=true
BOOKINGS_DB=momay_buu              # db ที่เก็บ bookings ใน cluster
BOOKINGS_COLLECTION=bookings
EARLY_ALLOWANCE_MIN=15             # เปิดก่อนเวลา booking ได้กี่นาที
CHECK_INTERVAL=3000               # ตรวจทุกกี่ ms

# ── Tuya OpenAPI ──
TUYA_ACCESS_ID=your_tuya_access_id
TUYA_ACCESS_SECRET=your_tuya_access_secret
TUYA_BASE_URL=https://openapi.tuyaus.com   # us / eu / cn / in
