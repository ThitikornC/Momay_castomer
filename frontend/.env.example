# Frontend — Environment Variables
# Copy to .env.local for local dev, or set in Railway dashboard

# Railway gateway URL — Layer 1 will use this as the default API base
# Set this to your deployed API Gateway URL on Railway
VITE_GATEWAY_URL=https://your-gateway.railway.app

# Default home route — set to /layer1 on Railway so the app opens Layer 1 directly
VITE_HOME=/layer1

# Device/Config gateway (gateway/ service) — หน้า /settings + dashboard ดึงห้อง/อุปกรณ์จากที่นี่
# local dev = http://localhost:8002 ; production = URL ของ gateway บน Railway
VITE_DEVICES_API=http://localhost:8002
