# ── Relay (รันที่ local 1 ตัว/site — ดึง RTSP จาก registry เอง ไม่ต้องตั้ง RTSP ที่นี่) ──
GATEWAY_URL=https://your-gateway.up.railway.app   # gateway ที่เก็บ camera devices (/api/devices?category=camera)
SERVER_URL=wss://your-cctv-server.up.railway.app/ws/relay   # cctv server (/ws/relay)
RELAY_KEY=your-secure-random-key-here              # ต้องตรงกับ cctv server
REFRESH_SEC=30                                     # ดึงรายการกล้องใหม่ทุกกี่วินาที

# ค่า default ต่อกล้อง (ถ้าไม่ได้ตั้งใน settings ราย device)
FRAME_WIDTH=640
FRAME_HEIGHT=480
FPS=15
JPEG_QUALITY=40
RTSP_TRANSPORT=tcp                                 # tcp|udp

# ── ตั้ง RTSP ของแต่ละกล้องในหน้า /settings (อุปกรณ์ประเภทกล้อง: camId + rtspUrl) ──
# ── Server (ตั้งบน Railway): RELAY_KEY (ตรงกับ relay), PORT (Railway ใส่ให้เอง) ──
